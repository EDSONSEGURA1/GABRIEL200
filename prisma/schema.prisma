generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Equipo {
  id             Int             @id @default(autoincrement())
  nombre         String
  codigo         String          @unique
  categoria      String
  mantenimientos Mantenimiento[]
}

model Mantenimiento {
  id          Int    @id @default(autoincrement())
  descripcion String?
  equipoId    Int
  equipo      Equipo @relation(fields: [equipoId], references: [id])
}
